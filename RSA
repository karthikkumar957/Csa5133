p = 3
q = 11

n = p * q
phi = (p - 1) * (q - 1)

e = 3


for i in range(1, phi):
    if (e * i) % phi == 1:
        d = i
        break

print("Public Key (e,n):", (e, n))
print("Private Key (d,n):", (d, n))

msg = 7


c = (msg ** e) % n
print("Encrypted message:", c)


m = (c ** d) % n
print("Decrypted message:", m)
